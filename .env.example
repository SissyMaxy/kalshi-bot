# Kalshi Bot Configuration
# Copy this file to .env and fill in your values
# NEVER share this file or commit it to git

# Kalshi API credentials
# Get these from https://kalshi.com → Settings → API Keys
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi-private-key.pem

# Environment: "demo" or "live"
# Start with demo! Only switch to live when you're confident.
KALSHI_ENV=demo

# Anthropic API key (for Claude sanity checks on trades)
# Get from https://console.anthropic.com → Settings → API Keys
# Optional — bot works without it, just skips the sanity check
ANTHROPIC_API_KEY=
